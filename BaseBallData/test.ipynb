    "import sqlite3\n",
    "\n",
    "conn = sqlite3.connect(\"kbo.db\")\n",
    "cur = conn.cursor()\n",
    "\n",
    "cur.execute(\"PRAGMA table_info(games)\")\n",
    "for row in cur.fetchall():\n",
    "    print(row)\n",
    "\n",
    "conn.close()"
   ]
